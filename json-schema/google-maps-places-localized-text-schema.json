{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocalizedText",
  "type": "object",
  "description": "A localized text string",
  "properties": {
    "text": {
      "type": "string",
      "description": "The localized text value"
    },
    "languageCode": {
      "type": "string",
      "description": "BCP-47 language code of the text"
    }
  }
}