{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "SearchTextRequest",
  "type": "object",
  "properties": {
    "textQuery": {
      "type": "string"
    },
    "includedType": {
      "type": "string"
    },
    "languageCode": {
      "type": "string"
    },
    "regionCode": {
      "type": "string"
    },
    "rankPreference": {
      "type": "string"
    },
    "maxResultCount": {
      "type": "integer"
    },
    "priceLevels": {
      "type": "array"
    },
    "openNow": {
      "type": "boolean"
    },
    "minRating": {
      "type": "number"
    },
    "strictTypeFiltering": {
      "type": "boolean"
    }
  }
}